prebuilt_kernel_modules {
    name: "microdroid_gki_kernel_modules-android16-6.12-arm64",
    srcs: [
        "cctrng.ko",
        "open-dice.ko",
        "vcpu_stall_detector.ko",
        "virtio_blk.ko",
        "virtio_console.ko",
        "virtio_pci.ko",
        "virtio_pci_legacy_dev.ko",
        "virtio_pci_modern_dev.ko",
        "vmw_vsock_virtio_transport.ko",
        "zram.ko",
        "zsmalloc.ko",
    ],
    kernel_version: "6.12",
    no_full_install: true,
    visibility: ["//visibility:private"],
}

filegroup {
    name: "microdroid_gki_kernel_prebuilts-android16-6.12-arm64",
    srcs: ["kernel-6.12"],
    visibility: ["//packages/modules/Virtualization:__subpackages__"],
}

android_filesystem {
    name: "microdroid_gki_modules-android16-6.12-arm64",
    deps: [
        "microdroid_gki_kernel_modules-android16-6.12-arm64",
    ],
    type: "compressed_cpio",
    visibility: ["//packages/modules/Virtualization:__subpackages__"],
}
