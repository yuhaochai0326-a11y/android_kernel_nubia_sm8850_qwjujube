/dts-v1/;
/plugin/;

#include "tuna-sde-display-mtp.dtsi"

/ {
	model = "Qualcomm Technologies, Inc. Tuna ATP";
	compatible = "qcom,tuna-atp", "qcom,tuna", "qcom,tunap-atp", "qcom,tunap",
			"qcom,atp";
	qcom,msm-id = <681 0x10000>, <655 0x10000>, <694 0x10000>;
	qcom,board-id = <33 0>;
};
